export async function bubbleSort(arr, setArr) {
  let copy = [...arr];

  for (let i = 0; i < copy.length; i++) {
    for (let j = 0; j < copy.length - i - 1; j++) {
      if (copy[j] > copy[j + 1]) {
        [copy[j], copy[j + 1]] = [copy[j + 1], copy[j]];
        setArr([...copy]);

        await new Promise(r => setTimeout(r, 50));
      }
    }
  }
}
